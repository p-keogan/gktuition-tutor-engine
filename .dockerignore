# Repo content the runtime image doesn't need. Keeps the build context small
# (faster `docker build`) and prevents accidentally shipping local secrets.

# VCS + editor
.git
.gitignore
.gitattributes
.github
.vscode
.idea

# Local caches
**/__pycache__
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.venv*
**/*.egg-info

# Compiled / scratch
**/*.pyc
**/*.pyo
**/*.pyd
**/.DS_Store

# Things that aren't the runtime API — kept out of the build context so that
# touching a tutorial or notebook doesn't bust the Docker layer cache.
content-pipeline/
dags/
docs/
eval/
examples/
pipelines/
snowflake/
widget/

# scripts/ — exclude developer-side tools but let the runtime-required
# always_warm.py through so the AGENT_18 'warm' Fly process can run it.
scripts/*
!scripts/always_warm.py

# corpus/ — explicitly NOT ignored. The runtime image's voice anchor reads
# from /app/corpus, populated by `COPY corpus /app/corpus` in the Dockerfile
# (AGENT_DAY_31, voice-anchor production activation). Without an explicit
# include line the bundled corpus would still ship (none of the patterns
# above exclude it), but stating the inclusion intent is the documentation
# the next agent will look for.
!corpus/

# Repo-level docs & READMEs
README.md
AGENT_*.md

# Secrets that should never make it into an image
.env*
*.pem
*.p8
*.key
